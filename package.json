{
  "name": "dispatch-stadium-routing",
  "version": "1.0.0",
  "description": "Deterministic staff auto-routing engine for stadium operations, with a generative AI layer for incident parsing and explanation.",
  "type": "module",
  "main": "src/scoring.js",
  "scripts": {
